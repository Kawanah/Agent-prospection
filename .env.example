# ================================
# Configuration Agent Prospection Kawanah Tourisme
# ================================
# Copiez ce fichier vers .env et remplissez vos vraies valeurs
# cp .env.example .env

# Application
APP_NAME="Agent Prospection Kawanah Tourisme"
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/prospection.db

# API Keys - AI
ANTHROPIC_API_KEY=sk-ant-xxxxx  # Claude API

# API Keys - Enrichissement (optionnel)
HUNTER_API_KEY=
DROPCONTACT_API_KEY=

# Pappers.fr — données légales françaises (dirigeants, SIREN, nouvelles structures)
# Gratuit 15 jours, puis payant : https://www.pappers.fr/api
PAPPERS_API_KEY=

# DataForSEO (optionnel — analyse SEO réelle : mots-clés positionnés, trafic organique)
# Créer un compte sur https://dataforseo.com → Account Settings → API Access
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Places API (source leads + avis Google)
# Console : https://console.cloud.google.com → APIs & Services → Places API
# Coût : ~0,017 $ / requête — 200 résultats ≈ 0,07 $
GOOGLE_PLACES_API_KEY=

# DATAtourisme (source leads : gîtes, chambres d'hôtes, activités)
# Inscription GRATUITE : https://www.datatourisme.fr/obtenir-et-utiliser-la-donnee/
DATATOURISME_API_KEY=

# Email Configuration (pour l'envoi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Redis (pour Celery)
REDIS_URL=redis://localhost:6379/0

# LinkedIn (optionnel - attention aux ToS)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Authentification JWT (OBLIGATOIRE)
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Admin dashboard
ADMIN_USERNAME=admin
# Générer : python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('votre-mdp'))"
ADMIN_PASSWORD_HASH=CHANGE_ME

# Garde-fous d'administration
# En production, laisser à false sauf besoin explicite et temporaire.
ENABLE_RUNTIME_SETTINGS=false
ENABLE_ADMIN_PURGE=false

# Garde-fous d'envoi email
# Phase développement/test : laisser à false pour ne rien envoyer réellement.
ENABLE_EMAIL_DELIVERY=false
ENABLE_AUTO_QUEUE=false
